# ═══════════════════════════════════════════════════════
# MAO Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── LANGFUSE (observability) ────────────────────────────
# Self-hosted: http://localhost:3001
# Cloud:       https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001

# ── DATABASE ────────────────────────────────────────────
# PostgreSQL — LangGraph checkpointer (prod)
DATABASE_URL=postgresql+asyncpg://mao:mao@localhost:5432/mao

# Redis — WebSocket session state
REDIS_URL=redis://localhost:6379/0

# ── API ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]
API_HOST=0.0.0.0
API_PORT=8000

# ── MEMORY SYSTEM ───────────────────────────────────────
# Kuzu embedded graph DB — path inside the api container
KUZU_DB_PATH=./data/kuzu

# Leave MEM0_API_KEY empty to use OSS/self-hosted Mem0
MEM0_API_KEY=

MEMORY_GRAPH_ENABLED=true

# Token budgets for each retrieval source (injected into agent prompts)
MEMORY_HOT_CACHE_TOKENS=2000
MEMORY_SEMANTIC_TOKENS=500
MEMORY_GRAPH_TOKENS=800
MEMORY_PROCEDURAL_TOKENS=300

# Max graph traversal depth for get_related()
MEMORY_GRAPH_HOPS=2

# Episode log retention window for consolidation
MEMORY_CONSOLIDATION_BATCH_DAYS=7

# Emit conflict alerts to frontend when contradictions are detected
MEMORY_CONFLICT_ALERT_ENABLED=true

# ── AGENT BEHAVIOUR ─────────────────────────────────────
DEFAULT_MODEL=claude-sonnet-4-6

# Heartbeat scheduler interval in seconds (active: 30, idle: 300)
HEARTBEAT_INTERVAL=30

# How many days of episode logs to retain on disk
MEMORY_RETENTION_DAYS=7

# Enable EdgeClaw-style privacy-tier routing
PRIVACY_ROUTING_ENABLED=true

# Number of file edits that triggers a verification agent pass
VERIFICATION_THRESHOLD=3

# ── MCP SERVERS (optional) ──────────────────────────────
# Leave empty to disable individual MCP servers
GITHUB_MCP_URL=
POSTGRES_MCP_URL=

# ── FEATURE FLAGS ───────────────────────────────────────
EXTENDED_THINKING_ENABLED=true
THINKING_BUDGET_TOKENS=8000

# A2A cross-system agent protocol (disabled by default until Phase 7)
A2A_ENABLED=false

# Kairos autonomous daemon mode (disabled by default)
KAIROS_DAEMON_ENABLED=false
