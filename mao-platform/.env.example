# ═══════════════════════════════════════════════════════
# MAO Platform — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── LLM PROVIDERS ───────────────────────────────────────────────────────────
# At least one provider is required. All three can coexist.
#
# Model ID convention:
#   claude-*                    → Anthropic   e.g. claude-sonnet-4-6
#   ollama/<name>               → Ollama      e.g. ollama/llama3.2
#   ollama/<name>:<tag>         → Ollama      e.g. ollama/mistral:7b
#   <org>/<model>               → OpenRouter  e.g. openai/gpt-4o
#   google/gemini-2.0-flash-exp → OpenRouter  (any openrouter.ai model)

# Anthropic — required for claude-* models + extended thinking
# Leave empty ("") if you only use OpenRouter or Ollama
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenRouter — free signup, pay-per-token, 200+ models from every provider
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama — local inference, zero token cost, runs on your own hardware
# Install: https://ollama.ai   then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Model used for knowledge graph extraction (background, use cheapest)
# Examples: claude-haiku-4-5 | ollama/llama3.2 | openai/gpt-4o-mini
EXTRACTION_MODEL=claude-haiku-4-5

# Default model for new agents (overridden per-agent in registry.py)
DEFAULT_MODEL=claude-sonnet-4-6

# ── LANGFUSE (observability) ─────────────────────────────────────────────────
# Self-hosted: http://localhost:3001  |  Cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001

# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mao:mao@localhost:5432/mao
REDIS_URL=redis://localhost:6379/0

# ── API ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]
API_HOST=0.0.0.0
API_PORT=8000

# ── MEMORY SYSTEM ────────────────────────────────────────────────────────────
KUZU_DB_PATH=./data/kuzu
MEMORY_GRAPH_ENABLED=true
MEMORY_HOT_CACHE_TOKENS=2000
MEMORY_SEMANTIC_TOKENS=500
MEMORY_GRAPH_TOKENS=800
MEMORY_GRAPH_HOPS=2
MEMORY_CONSOLIDATION_BATCH_DAYS=7
MEMORY_CONFLICT_ALERT_ENABLED=true

# ── AGENT BEHAVIOUR ──────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=30
MEMORY_RETENTION_DAYS=7
PRIVACY_ROUTING_ENABLED=true
VERIFICATION_THRESHOLD=3
EXTENDED_THINKING_ENABLED=true
THINKING_BUDGET_TOKENS=8000

# ── MCP SERVERS (optional) ───────────────────────────────────────────────────
GITHUB_MCP_URL=
POSTGRES_MCP_URL=

# ── FEATURE FLAGS ────────────────────────────────────────────────────────────
A2A_ENABLED=false
KAIROS_DAEMON_ENABLED=false
